# Example environment variables for GYMVERSE backend
# Copy this file to `.env` and fill in real secrets before running

# Server port (optional, defaults to 5000)
PORT=5000

# MongoDB connection string (required)
# Example local MongoDB: mongodb://localhost:27017/gymverse
MONGO_URI=

# JWT secrets
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# OpenAI API key (if used by AI services)
OPENAI_API_KEY=

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Cloudinary (if used)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe key (if used)
STRIPE_SECRET_KEY=

# Email SMTP settings (if used)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=